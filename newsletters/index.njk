---
layout: base.njk
title: Newsletter Archive
description: Every issue of the Wednesday Briefing — field-tested AI sourcing techniques, tool reviews, and automation recipes from the lab.
permalink: /newsletters/
eleventyExcludeFromCollections: true
---

<section class="archive-hero">
  <div class="container-narrow">
    <div class="eyebrow">Newsletter</div>
    <h1 class="archive-title">The Wednesday Briefing</h1>
    <p class="archive-dek">
      One issue every Wednesday at 10am London. Field-tested AI sourcing techniques,
      honest tool reviews from the 2026 lab, and the week's best automation recipe.
      Every issue free, forever.
    </p>
  </div>
</section>

<section class="archive-list">
  <div class="container-narrow">
    {% set newsletters = collections.newsletter | reverse %}
    {% if newsletters.length > 0 %}
      {% for post in newsletters %}
      <a href="{{ post.url }}" class="issue-row">
        <div class="issue-left">
          {% if post.data.issue %}<span class="issue-num">#{{ post.data.issue }}</span>{% endif %}
        </div>
        <div class="issue-mid">
          <div class="issue-meta">
            {% if post.data.pillar %}<span>{{ post.data.pillar }}</span>{% endif %}
            <span class="issue-date">{{ post.data.date | date('%d %b %Y') }}</span>
          </div>
          <h2 class="issue-title">{{ post.data.title }}</h2>
          {% if post.data.dek %}<p class="issue-dek">{{ post.data.dek }}</p>{% endif %}
        </div>
        <div class="issue-right">
          <span class="issue-arrow">→</span>
        </div>
      </a>
      {% endfor %}
    {% else %}
      <div class="empty-state">
        <div class="empty-eyebrow">Coming soon</div>
        <p>The first issue publishes Wednesday. Check back then, or follow <a href="https://www.linkedin.com/in/sourcing-strategist/" target="_blank" rel="noopener">Brendan on LinkedIn</a> for the announcement.</p>
      </div>
    {% endif %}
  </div>
</section>

<style>
.archive-hero {
  padding: var(--s-8) 0 var(--s-5);
  border-bottom: 1px solid var(--border-subtle);
}

.archive-title {
  font-family: var(--f-display);
  font-weight: 900;
  font-size: clamp(40px, 6vw, 64px);
  line-height: 0.98;
  text-transform: uppercase;
  letter-spacing: 0.01em;
  color: var(--parch);
  margin-bottom: var(--s-3);
}

.archive-dek {
  font-size: 18px;
  line-height: 1.6;
  color: var(--slate);
  max-width: 580px;
}

.archive-list { padding: var(--s-5) 0 var(--s-7); }

.issue-row {
  display: grid;
  grid-template-columns: 80px 1fr 40px;
  gap: var(--s-4);
  padding: var(--s-4) 0;
  border-bottom: 1px solid var(--border-subtle);
  text-decoration: none;
  color: inherit;
  transition: background 180ms ease;
  align-items: start;
}

.issue-row:hover {
  background: rgba(255, 195, 0, .025);
}

.issue-row:hover .issue-arrow {
  color: var(--gold);
  transform: translateX(4px);
}

.issue-row:hover .issue-title {
  color: var(--gold);
}

.issue-num {
  font-family: var(--f-display);
  font-weight: 900;
  font-size: 28px;
  color: var(--gold4);
  line-height: 1;
  transition: color 180ms ease;
}

.issue-row:hover .issue-num { color: var(--gold); }

.issue-meta {
  display: flex;
  gap: var(--s-3);
  align-items: center;
  font-family: var(--f-mono);
  font-size: 10px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  color: var(--slate);
  margin-bottom: var(--s-2);
}

.issue-date::before {
  content: '·';
  margin-right: var(--s-3);
  color: var(--slate);
}

.issue-title {
  font-family: var(--f-display);
  font-weight: 700;
  font-size: clamp(20px, 2.2vw, 26px);
  text-transform: uppercase;
  letter-spacing: 0.01em;
  color: var(--parch);
  margin-bottom: var(--s-2);
  line-height: 1.15;
  transition: color 180ms ease;
}

.issue-dek {
  font-size: 15px;
  color: var(--slate);
  line-height: 1.55;
}

.issue-arrow {
  font-family: var(--f-mono);
  font-size: 18px;
  color: var(--slate);
  transition: color 180ms ease, transform 180ms ease;
  display: block;
  padding-top: 4px;
}

.empty-state {
  text-align: center;
  padding: var(--s-7) var(--s-4);
  background: var(--navy);
  border: 1px dashed var(--border-med);
  border-radius: var(--r-card);
}

.empty-eyebrow {
  font-family: var(--f-mono);
  font-size: 11px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: var(--gold);
  margin-bottom: var(--s-3);
}

.empty-state p {
  font-size: 16px;
  color: var(--slate);
  line-height: 1.6;
  max-width: 440px;
  margin: 0 auto;
}

.empty-state a {
  color: var(--gold);
  border-bottom: 1px solid rgba(255, 195, 0, .3);
  text-decoration: none;
}

@media (max-width: 600px) {
  .issue-row {
    grid-template-columns: 60px 1fr 24px;
    gap: var(--s-3);
  }
  .issue-num { font-size: 22px; }
  .issue-title { font-size: 18px; }
  .issue-meta { font-size: 9px; }
}
</style>
